# --- Pflicht ---
DATABASE_URL=postgres://user:pass@localhost:5432/expertnetwork
JWT_SECRET=bitte-langen-zufaelligen-wert-eintragen

# --- Admin-Seeding (idempotent, bei jedem Start) ---
ADMIN_EMAIL=admin@phalanx.example
ADMIN_PASSWORD=bitte-aendern

# --- E-Mail (Default: Konsolen-Stub, wenn nicht gesetzt) ---
# Empfohlen: Brevo (EU-Anbieter, gleicher Account wie Capitalmatch)
MAIL_PROVIDER=brevo
BREVO_API_KEY=
# Alternative: MAIL_PROVIDER=resend + RESEND_API_KEY=
MAIL_FROM=Phalanx Expert Network <noreply@ihre-domain.de>

# --- Dokumenten-Tresor (Railway: Volume auf /data mounten) ---
STORAGE_DIR=

# --- URLs / Sonstiges ---
APP_URL=http://localhost:5173
NODE_ENV=development
